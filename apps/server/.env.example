NODE_ENV=production
PORT=4000
CLIENT_ORIGIN=https://mojo-pravah.sa-fet.com,http://localhost:5173
JWT_SECRET=replace-this-in-production
JWT_EXPIRES_IN=8h
USE_REDIS_ADAPTER=false
REDIS_URL=redis://redis:6379
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=
# Optional alternative to the 3 vars above: full service account JSON as one line
FIREBASE_SERVICE_ACCOUNT_JSON=
# Optional for ADC mode (for example, when running on GCP or with mounted key file)
GOOGLE_APPLICATION_CREDENTIALS=
